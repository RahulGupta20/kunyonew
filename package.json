{
  "name": "kunyo-gaming-store",
  "version": "1.0.0",
  "description": "Nepal's #1 Gaming Store - PUBG UC, Free Fire Diamonds, Gift Cards",
  "main": "index.html",
  "scripts": {
    "sass": "sass scss/main.scss css/style.css --watch --no-source-map",
    "sass:build": "sass scss/main.scss css/style.css --style compressed --no-source-map",
    "sass:product": "sass scss/pages/product-detail.scss css/product-detail.css --watch --no-source-map",
    "sass:product:build": "sass scss/pages/product-detail.scss css/product-detail.css --style compressed --no-source-map",
    "sass:auth": "sass scss/pages/auth.scss css/auth.css --watch --no-source-map",
    "sass:auth:build": "sass scss/pages/auth.scss css/auth.css --style compressed --no-source-map",
    "sass:cart": "sass scss/cart.scss css/cart.css --watch --no-source-map",
    "sass:cart:build": "sass scss/cart.scss css/cart.css --style compressed --no-source-map",
    "sass:checkout": "sass scss/checkout.scss css/checkout.css --watch --no-source-map",
    "sass:checkout:build": "sass scss/checkout.scss css/checkout.css --style compressed --no-source-map",
    "sass:all": "sass scss:css --watch --no-source-map",
    "sass:all:build": "sass scss:css --style compressed --no-source-map",
    "dev": "npm run sass"
  },
  "keywords": [
    "gaming",
    "top-up",
    "nepal",
    "pubg",
    "free-fire",
    "gift-cards"
  ],
  "author": "KUNYO",
  "license": "ISC",
  "devDependencies": {
    "sass": "^1.69.5"
  },
  "dependencies": {
    "bootstrap": "^5.3.2"
  }
}
